# Copy to .env for local development. Real .env files are git-ignored.
# See vault4/02-Architecture/security_and_configuration.md

# Application environment: local | staging | production
APP_ENV=local

# Human-readable service name (surfaced in health + OpenAPI metadata)
APP_NAME=Dynamic Pricing Optimization Platform API

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Comma-separated list of origins allowed to call the API (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database (SQLAlchemy URL). Provider is swappable via this value alone.
# SQLite (local default):
DATABASE_URL=sqlite:///./var/dpop.db
# PostgreSQL (deployment) example:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/dpop
# Echo SQL to logs (debugging only)
DB_ECHO=false

# --- Reserved for later milestones ---
# FILE_STORAGE_PATH=./var/storage
