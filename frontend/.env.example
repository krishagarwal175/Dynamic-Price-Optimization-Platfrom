# Frontend environment. Copy to `.env.local` for local overrides (git-ignored).
#
# Backend origin used in PRODUCTION builds. Leave empty for local development — the Vite
# dev server proxies /api to http://127.0.0.1:8000 (see vite.config.ts). In production
# (e.g. Vercel), set this to your deployed backend origin; the client appends /api/v1.
#
#   VITE_API_BASE_URL=https://api.your-backend-host.com
VITE_API_BASE_URL=
